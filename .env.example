 # === Postgres ===
POSTGRES_USER=finflow
POSTGRES_PASSWORD=finflow
POSTGRES_DB=finflow
POSTGRES_PORT=5432

# === API (backend) ===
API_PORT=4000
DATABASE_URL=postgres://finflow:finflow@postgres:5432/finflow
#Local DB URL: 
#DATABASE_URL=postgres://finflow:finflow@localhost:5432/finflow
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=1d
NODE_ENV=development

# === Frontend ===
VITE_API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173

# === Worker (Phase 4) ===
# Kafka: containers use kafka:29092, host (dev worker) uses localhost:9092
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=finflow-worker
KAFKA_DUE_SOON_TOPIC=expense.due_soon
KAFKA_CONSUMER_GROUP=finflow-due-soon
# How many days ahead counts as "due soon"
DUE_SOON_DAYS=3
# Cron for the daily scan (default: every day at 08:00)
DUE_SOON_CRON=0 8 * * *
# Run a scan once on boot (handy for local demos). Set to true to test end-to-end.
RUN_SCAN_ON_BOOT=false
# Port where the worker exposes /metrics for Prometheus
WORKER_METRICS_PORT=9100

# === Mailhog (fake SMTP) ===
SMTP_HOST=localhost
SMTP_PORT=1025
MAIL_FROM=finflow@example.com