 # === Postgres ===
POSTGRES_USER=finflow
POSTGRES_PASSWORD=finflow
POSTGRES_DB=finflow
POSTGRES_PORT=5432

# === API (backend) ===
API_PORT=4000
DATABASE_URL=postgres://finflow:finflow@postgres:5432/finflow
#Local DB URL: 
#DATABASE_URL=postgres://finflow:finflow@localhost:5432/finflow
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=1d
NODE_ENV=development

# === Frontend ===
VITE_API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173