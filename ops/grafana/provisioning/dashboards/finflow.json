{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "finflow overview",
  "uid": "finflow-overview",
  "schemaVersion": 39,
  "tags": ["finflow"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Targets up",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "up", "legendFormat": "{{job}}" }]
    },
    {
      "type": "timeseries",
      "title": "API request rate (req/s)",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count[5m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Due-soon events (events/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(worker_due_soon_events_produced_total[5m])",
          "legendFormat": "produced"
        },
        {
          "expr": "rate(worker_due_soon_events_consumed_total[5m])",
          "legendFormat": "consumed"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Emails sent & errors (per/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(worker_emails_sent_total[5m])",
          "legendFormat": "emails sent"
        },
        {
          "expr": "rate(worker_errors_total[5m])",
          "legendFormat": "errors"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 0
      }
    ]
  }
}
